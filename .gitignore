# Temporary and local exports
tmp/
*.tmp
*.bak
.~lock.*#
*.doc
*.docx
*.pdf
*.ppt
*.pptx
*.xls
*.xlsx

# Public root-document allowlist
/*.md
!/README.md
!/CHANGELOG.md
!/PROTOCOL.md
!/REPRODUCTION.md
!/DELIVERY.md

